# Database (Neon)
DATABASE_URL="postgresql://neondb_owner:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"

# Redis (Upstash)
UPSTASH_REDIS_REST_URL="https://YOUR_URL.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_TOKEN"

# Email (Resend)
RESEND_API_KEY="re_YOUR_KEY"

# Sentry
SENTRY_DSN="https://YOUR_KEY@sentry.io/YOUR_PROJECT"

# Auth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://your-hub.vercel.app"

# Scanner Droplet
SCANNER_DROPLET_IP="167.71.80.141"
SCANNER_DROPLET_PORT="3500"
SCANNER_API_KEY="set-a-strong-key-here"
